# Local PostgreSQL Configuration
# Create a database named 'marketbridge' in PostgreSQL before running the app
# Also create a shadow database for Prisma migrations
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/marketbridge"
DIRECT_URL="postgresql://postgres:your_password@localhost:5432/marketbridge"
SHADOW_DATABASE_URL="postgresql://postgres:your_password@localhost:5432/marketbridge_shadow"

# JWT Configuration
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-here

# Cloudinary Configuration (Image Uploads)
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_URL=cloudinary://[api_key]:[api_secret]@[cloud_name]
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
