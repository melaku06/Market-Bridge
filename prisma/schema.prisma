// Prisma Schema for MarketBridge
// Works with existing Supabase database structure

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User profiles - id references auth.users.id in Supabase
model Profile {
  id          String   @id
  email       String   @unique
  name        String
  phone       String?
  avatar_url  String?
  role        String   @default("customer")
  warehouse_id String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  credentials UserCredential?
  warehouse   Warehouse?   @relation(fields: [warehouse_id], references: [id])

  @@map("profiles")
}

// User credentials for password authentication
model UserCredential {
  user_id      String   @id
  password_hash String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_credentials")
}

// Warehouse/Seller information
model Warehouse {
  id             String   @id @default(uuid())
  name           String
  owner_name     String
  email          String   @unique
  phone          String
  address        String
  city           String
  country        String   @default("Ethiopia")
  business_type  String?
  bank_name      String?
  bank_account   String?
  tax_id         String?
  status         String   @default("pending_approval")
  member_since   DateTime @default(now())
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  profiles Profile[]

  @@map("warehouses")
}

// Product categories
model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image_url   String?
  parent_id   String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("categories")
}

// Products
model Product {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique
  description       String?
  short_description String?
  warehouse_id      String
  category_id       String?
  base_price        Decimal  @db.Decimal(15, 2)
  margin_percent    Decimal  @default(15) @db.Decimal(5, 2)
  discount_percent  Decimal  @default(0) @db.Decimal(5, 2)
  images            String[] @default([])
  rating            Decimal  @default(0) @db.Decimal(2, 1)
  review_count      Int      @default(0)
  sold_count        Int      @default(0)
  status            String   @default("pending")
  tags              String[] @default([])
  brand             String?
  sku               String?  @unique
  weight            String?
  colors            String[] @default([])
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("products")
}

// Inventory tracking
model Inventory {
  id           String   @id @default(uuid())
  warehouse_id String
  product_id   String
  quantity     Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([warehouse_id, product_id])
  @@map("inventory")
}

// User notifications
model Notification {
  id          String   @id @default(uuid())
  user_id     String
  type        String
  title       String
  message     String
  data        String?
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  @@map("notifications")
}
